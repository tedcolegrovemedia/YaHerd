{
  "manifest_version": 3,
  "name": "YaHerd",
  "description": "Pin comments to live websites, with screenshots, statuses and replies. Self-hosted.",
  "version": "1.0.6",
  "permissions": ["storage", "activeTab", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content/anchor.js", "content/overlay.js", "content/content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "WebComment"
  },
  "web_accessible_resources": [
    { "resources": ["content/overlay.css"], "matches": ["<all_urls>"] }
  ]
}
